<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="SettingsLabelInside">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingHorizontal">16dp</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:textColor">@color/primary</item>
    </style>

    <style name="SettingsDividerFull">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:layout_marginHorizontal">16dp</item>
        <item name="android:background">@color/surface_variant</item>
    </style>

    <style name="SettingsLabel">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingHorizontal">32dp</item>
        <item name="android:layout_marginTop">16dp</item>
        <item name="android:textSize">13sp</item>
        <item name="android:fontFamily">sans-serif-black</item>
        <item name="android:textColor">@color/primary</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <style name="SettingsCard">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginHorizontal">10dp</item>
        <item name="android:layout_marginTop">16dp</item>
        <item name="cardCornerRadius">8dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">0dp</item>
        <item name="cardBackgroundColor">@color/card_background</item>
    </style>

    <style name="SettingsItem" parent="Widget.Material3.Button.TextButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">56dp</item>
        <item name="iconTint">@color/text_secondary</item>
        <item name="iconPadding">16dp</item>
        <item name="android:drawableEnd">@drawable/caret_right</item>
    </style>

    <style name="SettingsDivider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:layout_marginStart">56dp</item>
        <item name="android:layout_marginEnd">16dp</item>
        <item name="android:background">@color/surface_variant</item>
    </style>
</resources>