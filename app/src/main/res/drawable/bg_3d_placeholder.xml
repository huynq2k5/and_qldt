<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="0dp" />
            <solid android:color="#EEF2FF" /> </shape>
    </item>

    <item
        android:bottom="15dp"
        android:left="25dp"
        android:right="25dp"
        android:top="30dp">
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <gradient
                android:angle="270"
                android:endColor="#104F46E5"
                android:startColor="#204F46E5" />
        </shape>
    </item>

    <item
        android:bottom="20dp"
        android:left="30dp"
        android:right="30dp"
        android:top="25dp">
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <gradient
                android:angle="135"
                android:endColor="#818CF8"
                android:startColor="#C7D2FE" />
        </shape>
    </item>

    <item
        android:bottom="60dp"
        android:left="35dp"
        android:right="35dp"
        android:top="30dp">
        <shape android:shape="rectangle">
            <corners android:radius="8dp" />
            <gradient
                android:angle="270"
                android:endColor="#00FFFFFF"
                android:startColor="#CCFFFFFF" />
        </shape>
    </item>

    <item
        android:bottom="35dp"
        android:left="45dp"
        android:right="45dp"
        android:top="40dp">
        <shape android:shape="oval">
            <stroke
                android:width="2dp"
                android:color="#FFFFFF" />
            <solid android:color="#20FFFFFF" />
        </shape>
    </item>
    <item
        android:bottom="42dp"
        android:left="52dp"
        android:right="52dp"
        android:top="47dp">
        <shape android:shape="oval">
            <solid android:color="#FFFFFF" />
        </shape>
    </item>

</layer-list>