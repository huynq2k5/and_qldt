<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary"
    android:fitsSystemWindows="true">

    <ImageButton
        android:id="@+id/btnBackQuiz"
        android:layout_width="48dp"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@null"
        android:src="@drawable/caret_left"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/white" />

    <TextView
        android:id="@+id/tvToolbarTitle"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:layout_marginHorizontal="8dp"
        android:ellipsize="end"
        android:fontFamily="sans-serif-black"
        android:gravity="center"
        android:maxLines="2"
        android:text="KIỂM TRA TRẮC NGHIỆM"
        android:textColor="@color/white"
        android:textSize="14sp"
        app:layout_constraintEnd_toStartOf="@+id/btnCloseQuiz"
        app:layout_constraintStart_toEndOf="@+id/btnBackQuiz"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/btnCloseQuiz"
        android:layout_width="48dp"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@null"
        android:src="@drawable/x"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/white" />

    <View
        android:id="@+id/bgContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_quiz_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvToolbarTitle" />

    <LinearLayout
        android:id="@+id/layoutTimerHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="?android:attr/colorBackground"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/bgContent">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="@null"
            android:src="@drawable/timer"
            app:tint="?android:attr/textColorPrimary" />

        <TextView
            android:id="@+id/tvQuizTimer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:fontFamily="sans-serif-black"
            android:text="00 : 00 : 00"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="20sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubmitQuiz"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/primary"
            android:fontFamily="sans-serif-black"
            android:paddingHorizontal="24dp"
            android:text="NỘP BÀI"
            android:textColor="@color/white"
            app:cornerRadius="12dp" />
    </LinearLayout>

    <View
        android:id="@+id/dividerQuiz"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/surface_variant"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutTimerHeader" />

    <LinearLayout
        android:id="@+id/layoutQuizNavigation"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="?android:attr/colorBackground"
        android:elevation="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPrevQuestion"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="60dp"
            android:layout_height="56dp"
            android:backgroundTint="?android:attr/colorBackground"
            android:contentDescription="Câu trước"
            app:cornerRadius="12dp"
            app:icon="@drawable/caret_left"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconTint="@color/primary"
            app:strokeColor="@color/surface_variant" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnQuestionList"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginHorizontal="12dp"
            android:layout_weight="1"
            android:fontFamily="sans-serif-medium"
            android:text="DANH SÁCH CÂU HỎI"
            android:textColor="@color/primary"
            app:cornerRadius="12dp"
            app:strokeColor="@color/surface_variant" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNextQuestion"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="60dp"
            android:layout_height="56dp"
            android:backgroundTint="?android:attr/colorBackground"
            android:contentDescription="Câu tiếp"
            app:cornerRadius="12dp"
            app:icon="@drawable/caret_right"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconTint="@color/primary"
            app:strokeColor="@color/surface_variant" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/layoutQuizNavigation"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/dividerQuiz">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?android:attr/colorBackground"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/tvQuestionText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/noto_sans"
                android:text="Nội dung câu hỏi sẽ hiển thị ở đây"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="16sp" />

            <RadioGroup
                android:id="@+id/rgAnswers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp">

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/rbOption1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:fontFamily="@font/noto_sans"
                    android:text="Lựa chọn 1"
                    android:textSize="15sp" />

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/rbOption2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:fontFamily="@font/noto_sans"
                    android:text="Lựa chọn 2"
                    android:textSize="15sp" />

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/rbOption3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:fontFamily="@font/noto_sans"
                    android:text="Lựa chọn 3"
                    android:textSize="15sp" />

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/rbOption4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/noto_sans"
                    android:text="Lựa chọn 4"
                    android:textSize="15sp" />
            </RadioGroup>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <FrameLayout
        android:id="@+id/layoutLoading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminateTint="@color/primary" />
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>