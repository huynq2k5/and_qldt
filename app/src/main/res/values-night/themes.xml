<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Quanlydaotao" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Main theme colors for Dark Mode -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/cnb_selected_background</item>
        <item name="colorOnPrimaryContainer">@color/primary</item>

        <!-- Force Surface Background in Dark Mode -->
        <item name="android:windowBackground">@color/surface_variant</item>
        <item name="android:colorBackground">@color/surface_variant</item>

        <item name="android:statusBarColor">@color/surface_variant</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>

        <!-- System Navigation Bar Dark Mode -->
        <item name="android:navigationBarColor">@color/card_background</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">false</item>

        <item name="android:fontFamily">@font/poppins</item>
    </style>
</resources>
